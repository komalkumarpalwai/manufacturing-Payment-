<apex:page renderAs="pdf"
           controller="InvoicePaymentController"
           showHeader="false"
           sidebar="false"
           standardStylesheets="false"
           contentType="application/pdf">
<html>
<head>
<style>
  body { font-family: Arial, sans-serif; font-size: 10px; color: #1a1a1a; margin: 0; padding: 0; }
</style>
</head>
<body>

<table width="100%" border="0" cellpadding="0" cellspacing="0">
<tr><td style="padding: 10px;">

  <!-- ══════════════════════════════
       OUTER BORDER WRAPPER
  ══════════════════════════════ -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="border: 2px solid #1740a8; border-radius: 4px;">
  <tr><td style="padding: 16px 28px 14px 28px;">

  <!-- ══════════════════════════════
       TOP HEADER ROW (compact)
  ══════════════════════════════ -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:10px;">
    <tr>
      <td width="50%" style="vertical-align:middle;">
        <table border="0" cellpadding="0" cellspacing="0">
          <tr>
            <td style="vertical-align:middle; padding-right:7px;">
              <img src="{!URLFOR($Resource.Logo)}" height="26" style="display:block;"/>
            </td>
            <td style="vertical-align:middle;">
              <div style="font-size:12px; font-weight:bold; color:#1a3a5c;">KRISH CARBON PVT LTD</div>
              <div style="font-size:7.5px; color:#555; margin-top:1px;">IndiaLand Tech Park, Coimbatore, Tamil Nadu 641035, India &nbsp;|&nbsp; 080-45813602</div>
            </td>
          </tr>
        </table>
      </td>
      <td width="50%" style="text-align:right; vertical-align:middle;">
      </td>
    </tr>
  </table>

  <!-- ══════════════════════════════
       BLUE BANNER (compact)
  ══════════════════════════════ -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:10px; background-color:#1740a8;">
    <tr>
      <td style="padding:14px 20px; vertical-align:bottom;">
        <div style="font-size:22px; font-weight:bold; color:#ffffff; letter-spacing:1.5px;">PAYMENT RECEIPT</div>
      </td>
      <td style="padding:14px 20px; text-align:right; vertical-align:bottom;">
        <div style="font-size:8px; color:#b8ccf0; letter-spacing:0.5px; margin-bottom:2px;">Amount Paid</div>
        <div style="font-size:20px; font-weight:bold; color:#ffffff;">
          &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
            <apex:param value="{!latestPayment.AMERP_Payment_Amount__c}"/>
          </apex:outputText>
        </div>
      </td>
    </tr>
  </table>

  <!-- ══════════════════════════════
       META STRIP (compact)
  ══════════════════════════════ -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:14px; border:1px solid #d8e4f4; background-color:#f4f7fd;">
    <tr>
      <td style="padding:8px 15px; vertical-align:middle; width:33%;">
        <div style="font-size:7px; color:#555; text-transform:uppercase; letter-spacing:0.6px; margin-bottom:2px; font-weight:bold;">Receipt No</div>
        <div style="font-size:10px; font-weight:bold; color:#111111;">{!latestPayment.Name}</div>
      </td>
      <td style="border-left:1px solid #d0daea; padding:8px 15px; vertical-align:middle; width:33%;">
        <div style="font-size:7px; color:#555; text-transform:uppercase; letter-spacing:0.6px; margin-bottom:2px; font-weight:bold;">Receipt Date</div>
        <div style="font-size:10px; font-weight:bold; color:#111111;">
          <apex:outputText value="{0,date,dd MMM yyyy}">
            <apex:param value="{!latestPayment.AMERP_Payment_Date__c}"/>
          </apex:outputText>
        </div>
      </td>
      <td style="border-left:1px solid #d0daea; padding:8px 15px; vertical-align:middle; width:34%;">
        <div style="font-size:7px; color:#555; text-transform:uppercase; letter-spacing:0.6px; margin-bottom:2px; font-weight:bold;">Payment Status</div>
        <div style="font-size:10px; font-weight:bold; color:#c97000;">{!invoice.AMERP_Payment_Status__c}</div>
      </td>
    </tr>
  </table>

  <!-- ══════════════════════════════
       TWO COLUMNS: INVOICE + CUSTOMER
  ══════════════════════════════ -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:14px;">
    <tr>

      <!-- LEFT: INVOICE DETAILS -->
      <td width="50%" style="vertical-align:top; padding-right:22px;">
        <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:8px;">
          <tr>
            <td style="font-size:9px; font-weight:bold; color:#1740a8; text-transform:uppercase; letter-spacing:1px; border-bottom:2px solid #1740a8; padding-bottom:4px;">
              Invoice Details
            </td>
          </tr>
        </table>
        <table width="100%" border="0" cellpadding="0" cellspacing="0">
          <tr>
            <td style="font-size:9px; color:#333333; padding:4px 0; width:130px; font-weight:bold;">Invoice Number</td>
            <td style="font-size:9px; font-weight:bold; color:#111111; padding:4px 0;">{!invoice.Name}</td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333333; padding:4px 0; font-weight:bold;">Order Reference</td>
            <td style="font-size:9px; color:#111111; padding:4px 0;">{!orderNumber}</td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333333; padding:4px 0; font-weight:bold;">Payment Mode</td>
            <td style="font-size:9px; font-weight:bold; color:#111111; padding:4px 0;">{!latestPayment.AMERP_Payment_Mode__c}</td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333333; padding:4px 0; font-weight:bold;">Invoice Date</td>
            <td style="font-size:9px; color:#111111; padding:4px 0;">
              <apex:outputText value="{0,date,dd MMM yyyy}">
                <apex:param value="{!invoice.AMERP_Invoice_Date__c}"/>
              </apex:outputText>
            </td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333333; padding:4px 0; font-weight:bold;">Due Date</td>
            <td style="font-size:9px; color:#111111; padding:4px 0;">
              <apex:outputText value="{0,date,dd MMM yyyy}">
                <apex:param value="{!invoice.AMERP_Due_Date__c}"/>
              </apex:outputText>
            </td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333333; padding:4px 0; font-weight:bold;">Currency</td>
            <td style="font-size:9px; color:#111111; padding:4px 0;">INR (&#8377;)</td>
          </tr>
          <!-- ── Invoice Total Amount ── -->
          <tr>
            <td style="font-size:9px; color:#333333; padding:4px 0; font-weight:bold; border-top:1px solid #e0e8f5;">Invoice Total Amount</td>
            <td style="font-size:9px; font-weight:bold; color:#111111; padding:4px 0; border-top:1px solid #e0e8f5;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!invoice.AMERP_Invoice_Amount__c}"/>
              </apex:outputText>
            </td>
          </tr>
          <!-- ── Total Amount Paid BEFORE this transaction ── -->
          <tr>
            <td style="font-size:9px; color:#333333; padding:4px 0; font-weight:bold;">Total Amount Paid</td>
            <td style="font-size:9px; font-weight:bold; color:#111111; padding:4px 0;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!amountPaidBeforeThis}"/>
              </apex:outputText>
            </td>
          </tr>
          <!-- ── Balance Due (before this transaction) ── -->
          <tr>
            <td style="font-size:9px; padding:4px 0; font-weight:bold; color:#1740a8;">Balance Due</td>
            <td style="font-size:9px; font-weight:bold; color:#1740a8; padding:4px 0;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!invoice.AMERP_Invoice_Amount__c - amountPaidBeforeThis}"/>
              </apex:outputText>
            </td>
          </tr>
        </table>
      </td>

      <!-- RIGHT: CUSTOMER DETAILS -->
      <td width="50%" style="vertical-align:top; padding-left:22px; border-left:1px solid #e0e8f5;">
        <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:8px;">
          <tr>
            <td style="font-size:9px; font-weight:bold; color:#1740a8; text-transform:uppercase; letter-spacing:1px; border-bottom:2px solid #1740a8; padding-bottom:4px;">
              Customer Details
            </td>
          </tr>
        </table>
        <table border="0" cellpadding="0" cellspacing="0">
          <tr>
            <td style="font-size:12px; font-weight:bold; color:#111111; padding-bottom:5px;">{!customerName}</td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333333; padding-bottom:2px;">{!customerAddress}</td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333333; padding-bottom:8px;">{!customerCity}</td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333333; padding-bottom:3px;">&#9742; {!customerPhone}</td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333333; padding-bottom:3px;">&#9993; {!customerEmail}</td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333333;">GSTIN-{!customerGST}</td>
          </tr>
        </table>
      </td>

    </tr>
  </table>

  <!-- ══════════════════════════════
       PAYMENT BREAKDOWN
  ══════════════════════════════ -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:6px;">
    <tr>
      <td style="font-size:12px; font-weight:bold; color:#111111;">Payment Breakdown</td>
    </tr>
  </table>

  <!-- Breakdown header -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0">
    <tr>
      <td width="18%" style="background-color:#1740a8; padding:7px 10px; font-size:8px; font-weight:bold; color:#ffffff; text-transform:uppercase; letter-spacing:0.6px;">Payment No</td>
      <td width="15%" style="background-color:#1740a8; padding:7px 10px; font-size:8px; font-weight:bold; color:#ffffff; text-transform:uppercase; letter-spacing:0.6px;">Date</td>
      <td width="14%" style="background-color:#1740a8; padding:7px 10px; font-size:8px; font-weight:bold; color:#ffffff; text-transform:uppercase; letter-spacing:0.6px;">Method</td>
      <td width="30%" style="background-color:#1740a8; padding:7px 10px; font-size:8px; font-weight:bold; color:#ffffff; text-transform:uppercase; letter-spacing:0.6px;">Reference</td>
      <td width="11%" style="background-color:#1740a8; padding:7px 10px; font-size:8px; font-weight:bold; color:#ffffff; text-transform:uppercase; letter-spacing:0.6px; text-align:right;">Amount Paid</td>
    </tr>
  </table>

  <!-- Breakdown data -->
  <apex:outputPanel rendered="{!latestPayment != null}">
    <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:14px;">
      <tr style="background-color:#f7f9fd;">
        <td width="18%" style="padding:8px 10px; font-size:9px; font-weight:bold; color:#111111; border-bottom:1px solid #e0e8f5;">{!latestPayment.Name}</td>
        <td width="15%" style="padding:8px 10px; font-size:9px; color:#222222; border-bottom:1px solid #e0e8f5;">
          <apex:outputText value="{0,date,dd MMM yyyy}">
            <apex:param value="{!latestPayment.AMERP_Payment_Date__c}"/>
          </apex:outputText>
        </td>
        <td width="14%" style="padding:8px 10px; font-size:9px; color:#222222; border-bottom:1px solid #e0e8f5;">{!latestPayment.AMERP_Payment_Mode__c}</td>
        <td width="30%" style="padding:8px 10px; font-size:9px; color:#333333; border-bottom:1px solid #e0e8f5;">
          <apex:outputText value="{!latestPayment.AMERP_Transaction_Reference__c}"/>
        </td>
        <td width="11%" style="padding:8px 10px; font-size:9px; font-weight:bold; color:#111111; text-align:right; border-bottom:1px solid #e0e8f5;">
          &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
            <apex:param value="{!latestPayment.AMERP_Payment_Amount__c}"/>
          </apex:outputText>
        </td>
      </tr>
    </table>
  </apex:outputPanel>
  <apex:outputPanel rendered="{!latestPayment == null}">
    <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:14px;">
      <tr>
        <td colspan="5" style="padding:12px 10px; font-size:9px; color:#888; font-style:italic; text-align:center; border-bottom:1px solid #e0e8f5;">
          No payment records available.
        </td>
      </tr>
    </table>
  </apex:outputPanel>

  <!-- ══════════════════════════════
       SUMMARY + SIGNATURE
  ══════════════════════════════ -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:14px;">
    <tr>
      <td width="50%" style="vertical-align:top;">&#160;</td>
      <td width="50%" style="vertical-align:top; padding-left:10px;">

        <!-- Summary rows -->
        <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:12px;">
          <tr>
            <td style="padding:6px 10px; font-size:9px; color:#333333; font-weight:bold;">Invoice Total Amount</td>
            <td style="padding:6px 10px; font-size:9px; color:#111111; text-align:right; font-weight:bold;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!invoice.AMERP_Invoice_Amount__c}"/>
              </apex:outputText>
            </td>
          </tr>
          <tr>
            <td style="padding:6px 10px; font-size:9px; color:#333333; font-weight:bold; border-top:1px solid #e0e8f5;">Total Amount Paid</td>
            <td style="padding:6px 10px; font-size:9px; color:#111111; text-align:right; font-weight:bold; border-top:1px solid #e0e8f5;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!amountPaid}"/>
              </apex:outputText>
            </td>
          </tr>
          <tr>
            <td style="padding:8px 10px; font-size:11px; font-weight:bold; color:#1740a8; border-top:2.5px solid #1740a8;">Balance Due</td>
            <td style="padding:8px 10px; font-size:13px; font-weight:bold; color:#1740a8; text-align:right; border-top:2.5px solid #1740a8;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!balanceDue}"/>
              </apex:outputText>
            </td>
          </tr>
        </table>

        <!-- Signature box with logo inside -->
        <table width="100%" border="0" cellpadding="0" cellspacing="0">
          <tr>
            <td style="text-align:right;">
              <table border="0" cellpadding="0" cellspacing="0" align="right">
                <tr>
                  <td style="border:1px dashed #9aadcc; width:130px; height:56px; text-align:center; vertical-align:middle; padding:5px 0;">
                    <img src="{!URLFOR($Resource.Logo)}" height="24" style="display:block; margin:0 auto 3px auto;"/>
                    <div style="font-size:7px; color:#aaa; text-transform:uppercase; letter-spacing:0.5px;">Stamp / Signature</div>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top:4px; text-align:right;">
                    <div style="font-size:7.5px; font-weight:bold; color:#1a3a5c; text-transform:uppercase; letter-spacing:0.6px;">Authorized Signatory</div>
                    <div style="font-size:7px; color:#555;">KRISH CARBON PVT LTD</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>

  <!-- ══════════════════════════════
       FOOTER INFO BOX
  ══════════════════════════════ -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:12px;">
    <tr>
      <td style="background-color:#eef3fb; border:1px solid #ccd8ee; padding:9px 14px; font-size:9px; color:#000000; line-height:1.5;">
        This is a computer-generated document and does not require a physical signature. For any discrepancies, please contact our accounts department at accounts@krishcarbon.com within 24 hours of receipt. Thank you for your business.
      </td>
    </tr>
  </table>

  <!-- ══════════════════════════════
       FOOTER BAR
  ══════════════════════════════ -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0">
    <tr>
      <td style="border-top:2px solid #1740a8; padding-top:8px; text-align:center;">
        <div style="font-size:10px; font-weight:bold; color:#1a3a5c;">KRISH CARBON PVT LTD</div>
        <div style="font-size:7.5px; color:#555; margin-top:2px;">Regd Office: IndiaLand Tech Park, Coimbatore, Tamil Nadu, India</div>
        <div style="font-size:7.5px; color:#1740a8; margin-top:3px;">
          https://www.arrayminds.com/&#160;&#160;&#160;&#160;INFO@KRISHCARBON.COM
        </div>
      </td>
    </tr>
  </table>

  </td></tr>
  </table>
  <!-- END OUTER BORDER WRAPPER -->

</td></tr>
</table>

</body>
</html>
</apex:page>